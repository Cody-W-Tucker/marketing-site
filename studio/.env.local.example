# Local preview URL used by `sanity dev`
SANITY_STUDIO_LOCAL_PREVIEW_URL=http://localhost:3000
SANITY_STUDIO_API_VERSION=2026-03-23
SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_HOSTNAME=your-sanity-studio-hostname
# Optional: set a real deploy token for CI/non-interactive deploys.
# Leave unset for local development so `sanity login` is used instead.
SANITY_STUDIO_APP_ID=your-sanity-studio-app-id
